{
  "entities": {
    "Installment": {
      "title": "Installment",
      "description": "Represents a real estate installment record.",
      "type": "object",
      "properties": {
        "customer": { "type": "string", "description": "Customer name" },
        "project": { "type": "string", "description": "Project name" },
        "unitCode": { "type": "string", "description": "Unit code" },
        "type": { "type": "string", "description": "Installment type" },
        "installmentCode": { "type": "string", "description": "Installment code" },
        "date": { "type": "string", "format": "date", "description": "Due date" },
        "value": { "type": "number", "description": "Installment value" },
        "netValue": { "type": "number", "description": "Net value" },
        "collected": { "type": "number", "description": "Collected amount" },
        "remaining": { "type": "number", "description": "Remaining amount" },
        "commercialPaper": { "type": "string", "description": "Commercial paper number" },
        "notes": { "type": "string", "description": "Notes" },
        "uid": { "type": "string", "description": "User ID of the owner" },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Last update timestamp" }
      },
      "required": ["customer", "project", "unitCode", "installmentCode", "date", "value", "netValue", "collected", "remaining", "uid"]
    }
  },
  "firestore": {
    "installments": {
      "schema": "Installment",
      "description": "Collection of installment records."
    }
  }
}
