rules_version = '2';

// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: installments
// Document ID: {installmentId}
// Fields:
//   - id: string (required) - Unique identifier
//   - customer: string (required) - Client name
//   - project: string (required) - Project name
//   - unitCode: string (required) - Unit name or number
//   - type: string (required) - Installment type
//   - installmentCode: string (required) - Installment code
//   - date: string (required) - Due date
//   - value: number (required) - Value
//   - netValue: number (required) - Net value
//   - collected: number (required) - Collected amount
//   - remaining: number (required) - Remaining amount
//   - commercialPaper: string (optional) - Commercial paper
//   - notes: string (optional) - Notes
//   - uid: string (required) - Owner UID
//   - createdAt: string (optional) - ISO 8601 creation timestamp
//
// ===============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) ||
        request.resource.data.uid == request.auth.uid;
    }

    function uidNotModified() {
      return !('uid' in request.resource.data) ||
        request.resource.data.uid == resource.data.uid;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function areImmutableFieldsUnchanged(fields) {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(fields);
    }

    function validStringLength(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }

    function isValidInstallment(data) {
      return hasRequiredFields(['id', 'customer', 'project', 'unitCode', 'type', 'installmentCode', 'date', 'value', 'netValue', 'collected', 'remaining', 'uid']) &&
             hasOnlyAllowedFields(['id', 'customer', 'project', 'unitCode', 'type', 'installmentCode', 'date', 'value', 'netValue', 'collected', 'remaining', 'commercialPaper', 'notes', 'uid', 'createdAt']) &&
             data.id is string && data.id.size() > 0 &&
             data.customer is string && data.customer.size() > 0 &&
             data.project is string && data.project.size() > 0 &&
             data.unitCode is string && data.unitCode.size() > 0 &&
             data.type is string &&
             data.installmentCode is string &&
             data.date is string &&
             data.value is number &&
             data.netValue is number &&
             data.collected is number &&
             data.remaining is number &&
             data.uid is string && data.uid == request.auth.uid;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /installments/{installmentId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidInstallment(request.resource.data);
      allow update: if isDocOwner() && isValidInstallment(request.resource.data) && uidNotModified();
      allow delete: if isDocOwner();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
